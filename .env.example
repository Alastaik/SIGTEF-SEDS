# ==========================================
# SIGTEF SEDS - Configurações de Ambiente
# Copie este arquivo para .env e preencha 
# com valores reais de produção
# ==========================================

# 1. Configurações de Domínio e SSL (Proxy Reverso)
DOMAIN_NAME=sigtef.com.br
# Email usado pelo Certbot para alertas de expiração do certificado SSL
LETSENCRYPT_EMAIL=admin@sigtef.com.br

# 2. Configurações do Banco de Dados
# Senhas fortes para ambiente de produção
SPRING_DATASOURCE_USERNAME=sigtef_user
SPRING_DATASOURCE_PASSWORD=senha_forte_do_banco_aqui
POSTGRES_DB=sigtef_db

# 3. Backend e Segurança
# Url jdbc apontando para o container docker "postgres" (não alterar se rodar via docker-compose)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/sigtef_db

# Chave secreta longa usada para assinar tokens JWT
# IMPORTANTE: Gere uma string aleatória (ex: openssl rand -base64 32)
JWT_SECRET=super_secret_key_for_production_environment_123456789

# Origens permitidas (CORS). Em produção, deixe os domínios válidos sem barra no final.
CORS_ALLOWED_ORIGINS=https://sigtef.com.br,https://www.sigtef.com.br

# Otimização de RAM da JVM (Ajuste baseado na VM. Exemplo 512m, 1g, 2g)
# Em VMs Micro de 1GB: -Xmx512m
# Em VMs ARM de 24GB: -Xmx2g
JAVA_OPTS="-Xmx1g -Xms512m"

# 4. Integrações Externas (E-mail)
RESEND_API_KEY=re_sua_chave_aqui

# 5. Rotinas de Manutenção
# Dias para retenção de logs e arquivos temporários (se ativado via script)
RETENTION_DAYS=7
